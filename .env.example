# Primary LLM provider — Gemini via Google's OpenAI-compatible endpoint.
# Get a free key at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Optional: override the model. Default is gemini-flash-lite-latest (cheap and
# currently reliable). NOTE: gemini-2.5-flash is retired for new projects (404)
# and the gemini-3.5-flash tier has returned sustained 503s for some accounts.
# A paid (billing-enabled) tier is required — the free tier is effectively 0 RPM
# for this app's fan-out. For higher quality, try gemini-3-flash-preview.
# CANCERPATIENT_MODEL=gemini-flash-lite-latest

# Optional: flip provider to OpenAI (requires OPENAI_API_KEY below)
# CANCERPATIENT_PROVIDER=openai
# OPENAI_API_KEY=

# Optional: NCBI Entrez credentials (raises PubMed rate limit from 3 to 10 req/s)
# NCBI_EMAIL=
# NCBI_API_KEY=

# Brave Search (REQUIRED for patient_source_search and social_resource_search,
# which are the main tools the patient-facing helpers use).
# Free tier 2k queries/mo at https://brave.com/search/api/
Brave_API=

# Optional: CORS — comma-separated list of allowed origins.
# CANCERPATIENT_ALLOWED_ORIGINS=https://your-domain.example

# Optional: cap concurrent active sessions to prevent runaway spend.
# CANCERPATIENT_MAX_ACTIVE_SESSIONS=20
